    { "name": "FileMode", "displayName": "FileMode", "value": "0664", "description": ["File mode (octal)."] },
    { "name": "IgnoreChownErrors", "displayName": "IgnoreChownErrors", "value": "yes", "description": ["Do not fail job if chown fails."], "select": ["yes", "no"] },
    { "name": "FollowSymlinks", "displayName": "FollowSymlinks", "value": "no", "description": ["Follow symlinks while walking."], "select": ["yes", "no"] }
